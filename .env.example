# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PAYSTACK_SECRET_KEY: Optional - Paystack secret key for Nigerian bank account verification
PAYSTACK_SECRET_KEY=""

# FLUTTERWAVE_SECRET_KEY: Optional - Flutterwave secret key for Nigerian bank account verification
FLUTTERWAVE_SECRET_KEY=""

# MONNIFY_SECRET_KEY: Optional - Monnify secret key for Nigerian bank account verification
MONNIFY_SECRET_KEY=""

# ONEPIPE_SECRET_KEY: Optional - OnePipe secret key for Nigerian bank account verification
ONEPIPE_SECRET_KEY=""
